generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id          String   @id @default(uuid())
  fullName    String
  email       String
  loanType    String
  loanAmount  Float
  status      String   @default("Pending")
  formData    String   // Stringified JSON containing all other application payload fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
