generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Application {
  id          String   @id @default(uuid())
  fullName    String
  email       String
  loanType    String
  loanAmount  Float
  status      String   @default("Pending")
  formData    String   // Stringified JSON containing all other application payload fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
